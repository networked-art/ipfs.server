{
  "name": "@1001/ipfs-server",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "upload": "set -a && . ./.env.production && set +a && node scripts/upload.ts",
    "kamal:setup": "set -a && . ./.env.production && set +a && kamal setup",
    "kamal:deploy": "set -a && . ./.env.production && set +a && kamal deploy",
    "kamal:sh": "set -a && . ./.env.production && set +a && kamal app exec -i --reuse \"sh\"",
    "changeset": "changeset"
  },
  "packageManager": "pnpm@10.30.0",
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0"
  },
  "dependencies": {
    "kubo-rpc-client": "^6.1.0"
  }
}
