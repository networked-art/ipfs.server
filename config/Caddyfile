{
	admin off
}

:5080 {
	handle /health {
		respond "OK" 200
	}

	@options method OPTIONS
	handle @options {
		reverse_proxy 127.0.0.1:5001
	}

	handle {
		basic_auth {
			{env.ADMIN_USER} {env.ADMIN_PASSWORD_HASH}
		}
		request_body {
			max_size 0
		}
		reverse_proxy 127.0.0.1:5001 {
			flush_interval -1
			transport http {
				response_header_timeout 0
			}
		}
	}
}
