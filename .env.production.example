# Deployment Variables
DOCKER_REGISTRY_USERNAME=
DEPLOY_HOST=
KAMAL_REGISTRY_PASSWORD=
IPFS_HOST=ipfs.1001.digital
IPFS_ADMIN_HOST=
ADMIN_PASSWORD_HASH=

# Gateway Configuration (optional)
# GATEWAY_NO_FETCH=true
# GATEWAY_DESERIALIZED_RESPONSES=true
# IPNS_RECORD_LIFETIME=336h
# STORAGE_MAX=30TB
# CONN_MGR_HIGH_WATER=900
# CONN_MGR_LOW_WATER=600
# BLOOM_FILTER_SIZE=1048576

# Garbage Collection (optional - disabled by default, enable for large repos only during maintenance)
# ENABLE_GC=false
# STORAGE_GC_WATERMARK=90
# GC_PERIOD=168h

# Pin Worker - file-based CID pinning (path inside container)
# PIN_CIDS_FILE=/data/ipfs/all_cids.txt
# PIN_CONCURRENCY=20
# PIN_TIMEOUT=2m
# PIN_STATE_DIR=/data/ipfs/pin-state

# Storage Volume (bind mount to dedicated disk for large datastores)
# IPFS_VOLUME=/mnt/ipfs/data

# Container Resource Limits (optional - sized for ~30TB datastore)
# CONTAINER_CPUS=4
# CONTAINER_MEMORY=32G
# RESOURCE_MGR_MAX_MEMORY=24GB
# RESOURCE_MGR_MAX_FILE_DESCRIPTORS=65536
