# Deployment Variables
DOCKER_REGISTRY_USERNAME=
DEPLOY_HOST=
KAMAL_REGISTRY_PASSWORD=
IPFS_HOST=ipfs.1001.digital
IPFS_ADMIN_HOST=
ADMIN_PASSWORD_HASH=

# Gateway Configuration (optional)
# GATEWAY_NO_FETCH=true
# GATEWAY_DESERIALIZED_RESPONSES=true
# IPNS_RECORD_LIFETIME=336h
# STORAGE_MAX=20GB
# CONN_MGR_HIGH_WATER=96
# CONN_MGR_LOW_WATER=32

# Storage Volume (optional - defaults to named Docker volume "ipfs_data")
# Use a host path for bind mounts, e.g. /mnt/ipfs/ipfs_data
# IPFS_VOLUME=ipfs_data

# Container Resource Limits (optional)
# CONTAINER_CPUS=2
# CONTAINER_MEMORY=6G
# RESOURCE_MGR_MAX_MEMORY=4GB
# RESOURCE_MGR_MAX_FILE_DESCRIPTORS=4096
